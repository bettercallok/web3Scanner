# ============================================================
# Web3 Security Scanner — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Django
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite; set to postgres:// for production)
DATABASE_URL=sqlite:///db.sqlite3

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Etherscan API Key — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Tenderly (honeypot simulation) — https://dashboard.tenderly.co
TENDERLY_ACCESS_KEY=your_tenderly_access_key_here
TENDERLY_PROJECT=your_project_slug
TENDERLY_ACCOUNT=your_account_slug

# Ollama (open-source LLM — runs locally via Docker)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=codellama:7b

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
